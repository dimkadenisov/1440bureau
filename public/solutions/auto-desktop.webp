		<link href="https://thevogne.ru/clients/ony/buro/style.css" rel="stylesheet" type="text/css">
		<style>
html{font-size:calc(100vw / 1440)}
.timeline-slide-top {height: calc(100vh - 100rem)}


.videoyab{display:none}
.videomob{display:none}

.hero-bg > video{position: absolute;
    width: 100%;
    height: 100%;
    object-fit: cover;
    
}

.videopcsd{position: absolute;
    width: 100%;
    height: 100%;
    object-fit: contain;
    
}

.new-blg{
    display: flex;
    gap: 54rem;
    padding-top: 32rem;
    color: #858585;
}

.new-blg.mcn{display:none}

@media screen and (max-width: 991px) {
    
    
    .content-right.s2-content-right .s2-image-wrap {
        width: 100%;
        height: auto;
        margin-top: 0;
        aspect-ratio: 1;
    }
    
    .content-left.s2-content-left {
        width: auto;
        margin-top: 0;
        padding-left: 0;
        max-width: 40vw;
    }
    
    .new-blg {
    display: flex;
    gap: 32rem;
    padding-top: 32rem;
    color: #858585;
    flex-wrap: wrap;
}

.content-left.s2-content-left {
        width: 100%;
        max-width: 100%;
    }
    
    .s2-image-wrap {
        width: 100%;
        margin: 0 auto 0rem;
    }
    
    /*.content-block.s2-content-block {*/
    /*    padding-left: 16px;*/
    /*    padding-right: 16px;*/
    /*    position: relative;*/
    /*    flex-direction: column;*/
    /*}*/
}

.text-regular.ngz.is-indented {
   
    font-size: 11rem;
    line-height: 13rem;
    letter-spacing: .08em;
    
    min-width: 150rem;
}

.container.hero-container {
    position: relative;
    z-index: 2;
}

.hero-bg:after{content: "";
    position: absolute;
    z-index: 2;
    width: 100%;
    height: 100%;
    background-image: linear-gradient(0deg, #000 6%, #fff0 62%), linear-gradient(#000, #fff0 26%);}

@media screen and (max-width:992px){
    
    .videopc{display:none}

.videoyab{display:block}
    
}

@media screen and (max-width:495px){
    
    .new-blg.pcn{display:none}
    
    .new-blg.mcn{display:flex;
        padding-top: 0;
        margin-bottom: 10vh;}
    
  .videoyab{display:none}
  .videomob{display:block} 
}


/* width */
.popup-form-wrapper::-webkit-scrollbar {
  width: 1px;
}

/* Track */
.popup-form-wrapper::-webkit-scrollbar-track {
  background: #EBEBEB; 
  border-radius:3px
}
 
/* Handle */
.popup-form-wrapper::-webkit-scrollbar-thumb {
  background: #0F1011; 
  border-radius:3px
}

/* Handle on hover */
.popup-form-wrapper::-webkit-scrollbar-thumb:hover {
  background: #0F1011; 
}

.tab-link:after{ 
content:"";
    position: absolute;
    top: 10rem;
    width: 12rem;
    height: 12rem;
    background: white;
    border-radius: 100%;
    right: 0;
    opacity: 0;
    
    right: -22rem;
    }
    
.tab-link.is-active:after{opacity:1}    

.char{
    opacity:1;
}

.image-cover + canvas{
    opacity: 1;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    aspect-ratio: auto;
}

.coml .char{
    opacity:0;
    transition: opacity 0s ease;
    transition-delay: calc( 0.01s * var(--char-index)  );
}

ul li{
    display: flex;
}

ul li:before{

content: "·";
    font-size: 28rem;
    line-height: 16rem;
    margin-left: -25rem;
    margin-right: 8rem;
    position: relative;
    top: -2rem;
}

.team-slide-image {
    flex: 1;
    justify-content: center;
    align-items: center;
    width: 100%;
    height: auto;
    display: flex;
    position: relative;
    max-height: calc(100% - 48rem);
}

@media screen and (max-height: 900px) and (min-width: 1280px) {

html {
    font-size: calc(100vw / 1840);
}
}
/*@media (min-width: 1440px) {
 html{font-size:1px}}*/
@media (max-width: 991px) {
html{font-size:calc(100vw / 768)}}
@media (max-width: 479px) {
html{font-size:calc(100vw / 390)}}
		
