---
// src/layouts/Layout.astro
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'ru' | 'en';
  canonicalUrl?: string;
}

const {
  title,
  description = 'Российская аэрокосмическая компания. Создаём низкоорбитальную спутниковую систему для широкополосной передачи данных.',
  lang = 'ru',
  canonicalUrl,
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://1440.space/globe-snapshot.webp" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="preconnect" href="https://1440.space" />
    <link rel="dns-prefetch" href="https://1440.space" />
    <link rel="icon" type="image/svg+xml" href="/logos/logo-icon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <slot />
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 0;
    padding: 8px 16px;
    background: #fff;
    color: #000;
    font-size: 14px;
    z-index: 9999;
    transition: top 0.1s;
  }
  .skip-link:focus {
    top: 0;
  }
</style>
