---
// src/components/Globe.astro
// Shows WebP snapshot immediately; lazy-loads WebGL globe on intersection.
---

<div class="globe-wrap" id="globe-wrap" aria-hidden="true">
  <img
    class="globe-fallback"
    id="globe-fallback"
    src="/globe-snapshot.webp"
    aria-hidden="true"
    alt=""
  />
  <canvas class="globe-canvas" id="globe-canvas" style="opacity:0"></canvas>
</div>

<style>
  .globe-wrap {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .globe-fallback,
  .globe-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .globe-fallback {
    object-fit: contain;
    transition: opacity 0.6s ease;
  }

  .globe-canvas {
    transition: opacity 0.6s ease;
  }
</style>

<script>
  const wrap = document.getElementById('globe-wrap')!;
  const canvas = document.getElementById('globe-canvas') as HTMLCanvasElement;
  const fallback = document.getElementById('globe-fallback') as HTMLImageElement;

  let loaded = false;

  const observer = new IntersectionObserver(async (entries) => {
    if (!entries[0]?.isIntersecting || loaded) return;
    loaded = true;
    observer.disconnect();

    const { GlobeRenderer } = await import('./globe/GlobeRenderer');

    const renderer = new GlobeRenderer(canvas);
    await renderer.loadWorldMap('/world.png').catch(() => {});
    renderer.buildOrbits();
    renderer.start();
    window.addEventListener('beforeunload', () => renderer.destroy(), { once: true });

    // Crossfade fallback → canvas
    canvas.style.opacity = '1';
    fallback.style.opacity = '0';
    fallback.addEventListener('transitionend', () => { fallback.style.display = 'none'; }, { once: true });
  }, { threshold: 0.1 });

  observer.observe(wrap);
</script>
