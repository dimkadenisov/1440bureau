---
// src/components/Technologies.astro
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const techImages = [
  'https://1440.space/wp-content/uploads/2024/08/Sputnikovaya-gruppirovka.png',
  'https://1440.space/wp-content/uploads/2024/08/Sputnik-V1.png',
  'https://1440.space/wp-content/uploads/2024/08/Terminal-lazernoj-svyazi.png',
  'https://1440.space/wp-content/uploads/2025/04/05-1-min.png',
  'https://1440.space/wp-content/uploads/2024/08/SHlyuzovaya-stanciya.png',
];

const techs = [1, 2, 3, 4, 5].map((n, i) => ({
  num: String(n).padStart(2, '0'),
  name: t(`tech.${n}_name` as any),
  desc: t(`tech.${n}_desc` as any),
  img: techImages[i]!,
}));
---

<section class="tech" id="technologies">
  <!-- Background images -->
  <div class="tech__bg" aria-hidden="true">
    {techs.map((tech, i) => (
      <img
        class={`tech__bg-img${i === 0 ? ' is-active' : ''}`}
        src={tech.img}
        alt=""
        loading={i === 0 ? 'eager' : 'lazy'}
        data-tech-img={i}
      />
    ))}
    <div class="tech__bg-overlay"></div>
  </div>

  <!-- Content -->
  <div class="tech__content section">
    <p class="label" data-animate>{t('tech.label')}</p>
    <div class="tech__cards" data-animate="fade">
      {techs.map((tech, i) => (
        <div class={`tech-card${i === 0 ? ' is-active' : ''}`} data-tech-index={i}>
          <span class="tech-card__num label">{tech.num}</span>
          <h3 class="tech-card__name">{tech.name}</h3>
          <p class="tech-card__desc">{tech.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .tech {
    position: relative;
    overflow: hidden;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* Background */
  .tech__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .tech__bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center right;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .tech__bg-img.is-active {
    opacity: 1;
  }

  .tech__bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.92) 40%,
      rgba(0, 0, 0, 0.5) 100%
    );
  }

  /* Content */
  .tech__content {
    position: relative;
    z-index: 1;
  }

  /* Cards — 3 columns */
  .tech__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-top: 40px;
  }

  .tech-card {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.25s ease, background 0.25s ease;
    cursor: default;
  }

  .tech-card.is-active {
    border-color: rgba(255, 255, 255, 0.35);
    background: rgba(255, 255, 255, 0.06);
  }

  .tech-card__num {
    display: block;
  }

  .tech-card__name {
    font-size: 17px;
    font-weight: 700;
    line-height: 1.3;
  }

  .tech-card__desc {
    font-size: 13px;
    color: var(--color-muted);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .tech__cards {
      grid-template-columns: repeat(2, 1fr);
    }
    .tech__bg-overlay {
      background: rgba(0, 0, 0, 0.75);
    }
  }

  @media (max-width: 560px) {
    .tech__cards {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const cards = document.querySelectorAll<HTMLElement>('.tech-card');
  const imgs = document.querySelectorAll<HTMLImageElement>('.tech__bg-img');

  function activate(index: number) {
    cards.forEach((c, i) => c.classList.toggle('is-active', i === index));
    imgs.forEach((img, i) => img.classList.toggle('is-active', i === index));
  }

  cards.forEach((card) => {
    card.addEventListener('mouseenter', () => {
      activate(Number(card.dataset.techIndex));
    });
  });
</script>
