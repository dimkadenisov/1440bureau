---
// src/components/Team.astro
import { useTranslations } from "../i18n/utils";
import Button from "./Button.astro";
import SectionTitle from "./SectionTitle.astro";
import type { Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const photos = [
  "/team/16-9-1-foto-Komanda_Obschaya-scaled.webp",
  "/team/16-9-2-foto-Komanda-i-sputniki-scaled.webp",
  "/team/16-9-4-foto-Komanda-i-sputniki-scaled.webp",
  "/team/16-9-6-foto-cUP_3-scaled.webp",
  "/team/3-foto-cUP_1-scaled.webp",
  "/team/16-9-5-foto-Sotrudniki-scaled.webp",
];
---

<section class="section" id="team">
  <p class="label" data-animate>{t("team.label")}</p>
  <SectionTitle class="team__title" data-animate>{t("team.title")}</SectionTitle
  >
  <div class="team__stats" data-animate="fade">
    <p class="team__stat">{t("team.stat_count")}</p>
    <p class="team__stat team__stat--muted">{t("team.stat_engineers")}</p>
  </div>

  <div class="team__carousel" data-animate="fade">
    {
      photos.map((src, i) => (
        <div class="team__photo">
          <img
            src={src}
            alt={`Team member ${i + 1}`}
            width="480"
            height="270"
            loading="lazy"
          />
        </div>
      ))
    }
  </div>

  <div class="team__cta" data-animate>
    <Button href="mailto:join@1440.space" variant="secondary"
      >{t("team.cta")} →</Button
    >
  </div>
</section>

<style>
  .team__title {
    max-width: 850px;
    margin: 12px 0 24px;
  }

  .team__stats {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 48px;
  }

  .team__stat {
    font-size: 15px;
    font-weight: 600;
  }

  .team__stat--muted {
    font-size: 13px;
    color: var(--color-muted);
    font-weight: 400;
  }

  .team__carousel {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    padding-bottom: 8px;
    margin-bottom: 40px;
  }

  .team__carousel::-webkit-scrollbar {
    display: none;
  }

  .team__photo {
    flex-shrink: 0;
    width: 480px;
    aspect-ratio: 16 / 9;
    border-radius: 6px;
    overflow: hidden;
    scroll-snap-align: start;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }

  .team__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .team__cta {
    display: flex;
  }
</style>

<script>
  document.querySelectorAll<HTMLImageElement>('.team__photo img').forEach((img) => {
    img.addEventListener('error', () => {
      (img.parentElement as HTMLElement).style.background = 'var(--color-surface)';
    });
  });
</script>
