---
// src/components/Solutions.astro
import { useTranslations } from '../i18n/utils';
import SectionTitle from './SectionTitle.astro';
import type { Lang } from '../i18n/utils';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const b = import.meta.env.BASE_URL;
const solutions = [
  { key: 'extractive', desktopSrc: `${b}solutions/extractive-desktop.webp`, mobileSrc: `${b}solutions/extractive-mobile.webp` },
  { key: 'geo',        desktopSrc: `${b}solutions/geo-desktop.webp`,        mobileSrc: `${b}solutions/geo-mobile.webp`        },
  { key: 'telecom',   desktopSrc: `${b}solutions/telecom-desktop.webp`,    mobileSrc: `${b}solutions/telecom-mobile.webp`    },
  { key: 'aviation',  desktopSrc: `${b}solutions/aviation-desktop.webp`,   mobileSrc: `${b}solutions/aviation-mobile.webp`   },
  { key: 'rail',      desktopSrc: `${b}solutions/rail-desktop.webp`,       mobileSrc: `${b}solutions/rail-mobile.webp`       },
  { key: 'maritime',  desktopSrc: `${b}solutions/maritime-desktop.webp`,   mobileSrc: `${b}solutions/maritime-mobile.webp`   },
  { key: 'auto',      desktopSrc: `${b}solutions/auto-desktop.webp`,       mobileSrc: `${b}solutions/auto-mobile.webp`       },
  { key: 'education', desktopSrc: `${b}solutions/education-desktop.webp`,  mobileSrc: `${b}solutions/education-mobile.webp`  },
  { key: 'health',    desktopSrc: `${b}solutions/health-desktop.webp`,     mobileSrc: `${b}solutions/health-mobile.webp`     },
  { key: 'emergency', desktopSrc: `${b}solutions/emergency-desktop.webp`,  mobileSrc: `${b}solutions/emergency-mobile.webp`  },
  { key: 'gov',       desktopSrc: `${b}solutions/gov-desktop.webp`,        mobileSrc: `${b}solutions/gov-mobile.webp`        },
];
---

<section class="solutions" id="solutions">
  <!-- Full-width background layer -->
  <div class="solutions__bg" aria-hidden="true">
    {solutions.map(({ key, desktopSrc, mobileSrc }, i) => (
      <picture
        class:list={['solutions__bg-picture', { 'solutions__bg-picture--active': i === 0 }]}
        data-solution={key}
      >
        <source media="(max-width: 768px)" srcset={mobileSrc} type="image/webp" />
        <source media="(min-width: 769px)" srcset={desktopSrc} type="image/webp" />
        <img
          src={desktopSrc}
          alt=""
          width="1920"
          height="1080"
          loading={i === 0 ? 'eager' : 'lazy'}
          fetchpriority={i === 0 ? 'high' : 'low'}
          decoding="async"
        />
      </picture>
    ))}
    <div class="solutions__bg-overlay"></div>
  </div>

  <!-- Constrained content -->
  <div class="section solutions__inner">
    <p class="label" data-animate>{t('solutions.label')}</p>
    <SectionTitle class="solutions__title" data-animate>{t('solutions.title')}</SectionTitle>

    <div class="solutions__accordion" role="list">
      {solutions.map(({ key }, i) => (
        <div
          class:list={['solutions__strip', { 'solutions__strip--active': i === 0 }]}
          role="listitem"
          data-solution={key}
          tabindex="0"
          aria-expanded={i === 0 ? 'true' : 'false'}
        >
          <div class="solutions__header">
            <span class="solutions__num label">{String(i + 1).padStart(2, '0')}</span>
            <span class="solutions__name">{t(`solutions.${key}` as any)}</span>
            <span class="solutions__arrow" aria-hidden="true">→</span>
          </div>

          <div class="solutions__body">
            <p class="solutions__desc">{t(`solutions.${key}_desc` as any)}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── Section (full-width) ── */
  .solutions {
    position: relative;
    overflow: hidden;
  }

  /* Content wrapper inherits .section max-width + padding */
  .solutions__inner {
    position: relative;
    z-index: 1;
  }

  .solutions__title {
    margin: 12px 0 32px;
  }

  /* ── Section-level background ── */
  .solutions__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .solutions__bg-picture {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  .solutions__bg-picture--active {
    opacity: 1;
  }

  .solutions__bg-picture img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .solutions__bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.82) 0%,
      rgba(0, 0, 0, 0.55) 50%,
      rgba(0, 0, 0, 0.35) 100%
    );
  }

  /* ── Accordion ── */
  .solutions__accordion {
    position: relative;
    z-index: 1;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* ── Strip ── */
  .solutions__strip {
    position: relative;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    cursor: pointer;
    height: 52px;
    transition: height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }

  .solutions__strip:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.4);
    outline-offset: -2px;
  }

  .solutions__strip--active {
    height: 280px;
  }

  @media (max-width: 768px) {
    .solutions__strip--active {
      height: 240px;
    }
  }

  /* ── Header row ── */
  .solutions__header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 52px;
    display: flex;
    align-items: center;
    padding: 0 var(--section-padding, 40px);
    gap: 16px;
    z-index: 1;
    transition: background 0.2s ease;
  }

  .solutions__strip:not(.solutions__strip--active):hover .solutions__header {
    background: rgba(255, 255, 255, 0.04);
  }

  .solutions__num {
    flex-shrink: 0;
    width: 28px;
    color: rgba(255, 255, 255, 0.35);
    transition: color 0.3s;
  }

  .solutions__strip--active .solutions__num {
    color: rgba(255, 255, 255, 0.6);
  }

  .solutions__name {
    flex: 1;
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.55);
    transition: color 0.3s;
  }

  .solutions__strip--active .solutions__name {
    color: #fff;
  }

  .solutions__strip:not(.solutions__strip--active):hover .solutions__name {
    color: rgba(255, 255, 255, 0.8);
  }

  .solutions__arrow {
    flex-shrink: 0;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.2);
    transition: color 0.3s, transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .solutions__strip--active .solutions__arrow {
    color: #fff;
    transform: rotate(90deg);
  }

  .solutions__strip:not(.solutions__strip--active):hover .solutions__arrow {
    color: rgba(255, 255, 255, 0.5);
  }

  /* ── Expanded body ── */
  .solutions__body {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0 var(--section-padding, 40px) 28px;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.3s ease 0.15s, transform 0.3s ease 0.15s;
    pointer-events: none;
  }

  .solutions__strip--active .solutions__body {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .solutions__desc {
    max-width: 540px;
    font-size: 18px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.75);
  }

  @media (max-width: 768px) {
    .solutions__header {
      padding: 0 20px;
    }
    .solutions__body {
      padding: 0 20px 20px;
    }
    .solutions__desc {
      font-size: 15px;
    }
  }
</style>

<script>
  function initSolutions() {
    const strips = document.querySelectorAll<HTMLElement>('.solutions__strip');
    const bgPictures = document.querySelectorAll<HTMLElement>('.solutions__bg-picture');

    function activate(target: HTMLElement) {
      const key = target.dataset.solution;
      strips.forEach((s) => {
        const isTarget = s === target;
        s.classList.toggle('solutions__strip--active', isTarget);
        s.setAttribute('aria-expanded', String(isTarget));
      });
      bgPictures.forEach((p) => {
        p.classList.toggle('solutions__bg-picture--active', p.dataset.solution === key);
      });
    }

    strips.forEach((strip) => {
      strip.addEventListener('click', () => activate(strip));
      strip.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          activate(strip);
        }
      });
    });
  }

  // Init on intersection to avoid running before DOM is ready
  const section = document.getElementById('solutions');
  if (section) {
    const obs = new IntersectionObserver((entries) => {
      if (entries[0]?.isIntersecting) {
        obs.disconnect();
        initSolutions();
      }
    });
    obs.observe(section);
  }
</script>
